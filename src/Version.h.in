#pragma once
// ─────────────────────────────────────────────────────────────────────────
// Version.h — GENERATED from CMake. DO NOT EDIT THE GENERATED COPY.
//
// Single source of truth for the POM2 version is the
//   project(pom2_imgui VERSION x.y ...)
// line in CMakeLists.txt. CMake's configure_file() expands the project
// version into the build tree at configure time, and re-runs whenever
// CMakeLists.txt changes — so bumping it in one place rebuilds every consumer.
//
// Docs (README.md, CLAUDE.md) still carry the version as prose and are bumped
// by hand; they cannot #include a header. Everything compiled lives here.
// ─────────────────────────────────────────────────────────────────────────

// Macro forms — usable in adjacent string-literal concatenation, e.g.
//   "POM2 " POM2_VERSION_STRING " - Apple II Emulator"
#define POM2_VERSION        "@PROJECT_VERSION@"   // e.g. "0.7"
#define POM2_VERSION_STRING "v" POM2_VERSION      // e.g. "v0.7"

namespace pom2 {
// constexpr forms — for std::string contexts / printf("%s", ...).
inline constexpr const char* kVersion       = POM2_VERSION;
inline constexpr const char* kVersionString = POM2_VERSION_STRING;
}  // namespace pom2
